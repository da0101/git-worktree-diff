{
  "name": "git-worktree-diff",
  "displayName": "Worktree Diff",
  "description": "Inspect local Git diffs across repositories, branches, and worktrees from inside VS Code.",
  "version": "1.2.4",
  "private": true,
  "publisher": "danilulmashev",
  "license": "UNLICENSED",
  "engines": {
    "vscode": "^1.96.0",
    "node": ">=20.0.0"
  },
  "categories": [
    "Source Control",
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./vs-code-extention/out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitWorktreeDiff",
          "title": "Worktree Diff",
          "icon": "vs-code-extention/media/icon.svg"
        }
      ]
    },
    "views": {
      "gitWorktreeDiff": [
        {
          "id": "gitWorktreeDiff.sidebar",
          "name": "Worktrees",
          "icon": "vs-code-extention/media/icon.svg"
        },
        {
          "id": "gitWorktreeDiff.history",
          "name": "History"
        },
        {
          "id": "gitWorktreeDiff.actions",
          "name": "Actions",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "gitWorktreeDiff.addRepo",
        "title": "Add Repository",
        "category": "Worktree Diff"
      },
      {
        "command": "gitWorktreeDiff.removeRepo",
        "title": "Remove Repository",
        "category": "Worktree Diff",
        "icon": "$(trash)"
      },
      {
        "command": "gitWorktreeDiff.refreshSidebar",
        "title": "Refresh Sidebar",
        "category": "Worktree Diff",
        "icon": "$(refresh)"
      },
      {
        "command": "gitWorktreeDiff.refreshHistory",
        "title": "Refresh History",
        "category": "Worktree Diff",
        "icon": "$(refresh)"
      },
      {
        "command": "gitWorktreeDiff.openNativeDiff",
        "title": "Open Native Diff",
        "category": "Worktree Diff",
        "icon": "$(diff)"
      },
      {
        "command": "gitWorktreeDiff.stageFile",
        "title": "Stage File",
        "category": "Worktree Diff",
        "icon": "$(add)"
      },
      {
        "command": "gitWorktreeDiff.unstageFile",
        "title": "Unstage File",
        "category": "Worktree Diff",
        "icon": "$(remove)"
      },
      {
        "command": "gitWorktreeDiff.discardFile",
        "title": "Discard File Changes",
        "category": "Worktree Diff",
        "icon": "$(discard)"
      },
      {
        "command": "gitWorktreeDiff.checkoutBranch",
        "title": "Checkout Branch",
        "category": "Worktree Diff",
        "icon": "$(git-branch)"
      },
      {
        "command": "gitWorktreeDiff.fetch",
        "title": "Fetch",
        "category": "Worktree Diff",
        "icon": "$(cloud-download)"
      },
      {
        "command": "gitWorktreeDiff.pull",
        "title": "Pull Fast-Forward",
        "category": "Worktree Diff",
        "icon": "$(arrow-down)"
      },
      {
        "command": "gitWorktreeDiff.pullWithRebase",
        "title": "Pull with Rebase",
        "category": "Worktree Diff",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "gitWorktreeDiff.pullWithStash",
        "title": "Stash, Pull, Unstash",
        "category": "Worktree Diff",
        "icon": "$(archive)"
      },
      {
        "command": "gitWorktreeDiff.push",
        "title": "Push",
        "category": "Worktree Diff",
        "icon": "$(arrow-up)"
      },
      {
        "command": "gitWorktreeDiff.stageAll",
        "title": "Stage All Changes",
        "category": "Worktree Diff",
        "icon": "$(add)"
      },
      {
        "command": "gitWorktreeDiff.unstageAll",
        "title": "Unstage All Changes",
        "category": "Worktree Diff",
        "icon": "$(remove)"
      },
      {
        "command": "gitWorktreeDiff.sendSelectionToAgent",
        "title": "Send Selection to Agent Terminal",
        "category": "Worktree Diff",
        "icon": "$(send)"
      },
      {
        "command": "gitWorktreeDiff.sendFileToAgent",
        "title": "Send File to Agent Terminal",
        "category": "Worktree Diff",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "gitWorktreeDiff.sendTreeFileToAgent",
        "title": "Send File or Selected Files to Agent Terminal",
        "category": "Worktree Diff",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "gitWorktreeDiff.addToGitignore",
        "title": "Add to .gitignore",
        "category": "Worktree Diff",
        "icon": "$(eye-closed)"
      },
      {
        "command": "gitWorktreeDiff.acceptOurs",
        "title": "Accept Current (Ours)",
        "category": "Worktree Diff",
        "icon": "$(check)"
      },
      {
        "command": "gitWorktreeDiff.acceptTheirs",
        "title": "Accept Incoming (Theirs)",
        "category": "Worktree Diff",
        "icon": "$(check)"
      },
      {
        "command": "gitWorktreeDiff.markResolved",
        "title": "Mark Resolved",
        "category": "Worktree Diff",
        "icon": "$(check-all)"
      },
      {
        "command": "gitWorktreeDiff.selectAllChangedFiles",
        "title": "Select All Changed Files",
        "category": "Worktree Diff",
        "icon": "$(check-all)"
      },
      {
        "command": "gitWorktreeDiff.clearSelectedFiles",
        "title": "Clear Selected Files",
        "category": "Worktree Diff",
        "icon": "$(clear-all)"
      },
      {
        "command": "gitWorktreeDiff.stageSelectedFiles",
        "title": "Stage Selected Files",
        "category": "Worktree Diff",
        "icon": "$(add)"
      },
      {
        "command": "gitWorktreeDiff.unstageSelectedFiles",
        "title": "Unstage Selected Files",
        "category": "Worktree Diff",
        "icon": "$(remove)"
      },
      {
        "command": "gitWorktreeDiff.discardSelectedFiles",
        "title": "Discard Selected Files",
        "category": "Worktree Diff",
        "icon": "$(discard)"
      },
      {
        "command": "gitWorktreeDiff.addSelectedToGitignore",
        "title": "Add Selected Files to .gitignore",
        "category": "Worktree Diff",
        "icon": "$(eye-closed)"
      },
      {
        "command": "gitWorktreeDiff.sendSelectedToAgent",
        "title": "Send Selected Files to Agent Terminal",
        "category": "Worktree Diff",
        "icon": "$(send)"
      },
      {
        "command": "gitWorktreeDiff.openCommitDiff",
        "title": "Open Commit Diff",
        "category": "Worktree Diff",
        "icon": "$(git-commit)"
      },
      {
        "command": "gitWorktreeDiff.openCommitFileDiff",
        "title": "Open Commit File Diff",
        "category": "Worktree Diff",
        "icon": "$(diff)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitWorktreeDiff.refreshSidebar",
          "when": "view == gitWorktreeDiff.sidebar",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.addRepo",
          "when": "view == gitWorktreeDiff.sidebar",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.refreshHistory",
          "when": "view == gitWorktreeDiff.history",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "gitWorktreeDiff.sendSelectionToAgent",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.sendFileToAgent",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "gitWorktreeDiff.openNativeDiff",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /file-.*/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.stageFile",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /file-.*/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.sendTreeFileToAgent",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /file-.*/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.unstageFile",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /file-.*/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.discardFile",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /file-.*/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.addToGitignore",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /file-.*/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.acceptOurs",
          "when": "view == gitWorktreeDiff.sidebar && viewItem == file-conflicted",
          "group": "inline"
        },
        {
          "command": "gitWorktreeDiff.acceptTheirs",
          "when": "view == gitWorktreeDiff.sidebar && viewItem == file-conflicted",
          "group": "inline"
        },
        {
          "command": "gitWorktreeDiff.markResolved",
          "when": "view == gitWorktreeDiff.sidebar && viewItem == file-conflicted",
          "group": "inline"
        },
        {
          "command": "gitWorktreeDiff.checkoutBranch",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /repo|main-worktree/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.fetch",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /repo|worktree/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.pull",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /repo|worktree/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.pullWithRebase",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /repo|worktree/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.pullWithStash",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /repo|worktree/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.push",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /repo|worktree/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.stageAll",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /repo|worktree/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.unstageAll",
          "when": "view == gitWorktreeDiff.sidebar && viewItem =~ /repo|worktree/",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.removeRepo",
          "when": "view == gitWorktreeDiff.sidebar && viewItem == repo",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.openCommitDiff",
          "when": "view == gitWorktreeDiff.history && viewItem == history-commit",
          "group": "navigation"
        },
        {
          "command": "gitWorktreeDiff.openCommitFileDiff",
          "when": "view == gitWorktreeDiff.history && viewItem =~ /history-file-.*/",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build:extension",
    "build:web": "npm --prefix web run build",
    "build:extension": "tsc -p vs-code-extention/tsconfig.json",
    "build": "npm run build:extension",
    "package:extension": "npm run build:extension && npx --yes @vscode/vsce package --out git-worktree-diff-$npm_package_version.vsix",
    "update:extension": "npm run package:extension && code --install-extension git-worktree-diff-$npm_package_version.vsix --force",
    "watch:extension": "tsc -watch -p vs-code-extention/tsconfig.json",
    "test:extension": "npm run build:extension && node --test vs-code-extention/test/*.test.cjs",
    "test": "npm run test:web && npm run test:extension",
    "test:web": "npm --prefix web run test",
    "lint:web": "npm --prefix web run lint"
  },
  "devDependencies": {
    "@types/node": "^20.19.24",
    "@types/vscode": "^1.96.0",
    "typescript": "~5.9.3"
  }
}
